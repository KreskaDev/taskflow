# TaskFlow — environment template. Copy to `.env` and fill in real values.
# NEVER commit a populated .env (see .gitignore). Secrets are runtime-injected (FR-100).

# --- PostgreSQL ---
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=changeme-local-only
POSTGRES_DB=taskflow
# Connection string used by the .NET API (EF Core / Npgsql)
ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=taskflow;Username=taskflow;Password=changeme-local-only
# Connection string used by the Next.js BFF session store (node-postgres `pg`)
DATABASE_URL=postgres://taskflow:changeme-local-only@localhost:5432/taskflow

# --- Google OAuth (Identity provider — sign-in only, FR-052/FR-090) ---
GOOGLE_CLIENT_ID=<from-google-cloud-console>
GOOGLE_CLIENT_SECRET=<from-google-cloud-console>

# --- Signing keys / secrets (FR-088, FR-091, FR-100) ---
# Shared HMAC key the BFF signs the 60s BFF->API identity carrier with, and the API validates (FR-091).
JWT_SIGNING_KEY=<random-64-char-hex>
# Key the BFF uses to sign/secure the session cookie machinery (FR-088).
SESSION_SECRET=<random-64-char-hex>

# --- Admission control (FR-087). At least ONE of these MUST be set or the BFF fails fast at startup. ---
# Comma-separated allowlist of admitted emails.
ADMISSION_EMAILS=you@example.com
# Google Workspace hosted-domain (id_token `hd` claim). Leave empty if using the allowlist only.
ADMISSION_HD=

# --- URLs ---
APP_URL=http://localhost:3000
# Internal-only API base URL the BFF proxy forwards to (API port not externally reachable, FR-091).
API_INTERNAL_URL=http://localhost:4311

# --- Session policy (FR-088). Defaults: 7-day absolute, 24-hour idle (research R10). ---
SESSION_ABSOLUTE_LIFETIME_HOURS=168
SESSION_IDLE_TIMEOUT_HOURS=24
